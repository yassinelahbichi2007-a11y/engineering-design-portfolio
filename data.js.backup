  <div class="design-loop-track">
    
    <!-- Box 1: OBSERVE -->
    <div class="design-loop-stage">
      <h3>OBSERVE</h3>
      <p class="design-loop-summary">Reading the environment before acting</p>
      <p style="margin: auto 0 0 0; font-size: 0.65rem; color: var(--text-secondary); text-transform: uppercase;">Stakeholders • Constraints • Context • Failure Points</p>
