    <!-- Box 5: ITERATE -->
    <div style="flex: 1; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--blue-accent); padding: var(--spacing-sm); border-radius: 6px; text-align: center; position: relative; z-index: 2; box-shadow: 0 2px 8px rgba(0,0,0,0.2); display: flex; flex-direction: column;">
      <h3 style="color: var(--blue-accent); margin: 0 0 8px 0; font-family: var(--font-head); font-size: 0.95rem;">ITERATE</h3>
      <p style="margin: 0 0 8px 0; font-size: 0.8rem; line-height: 1.3; color: var(--text-primary); flex: 1;">Refining decisions based on evidence</p>
      <p style="margin: auto 0 0 0; font-size: 0.65rem; color: var(--text-secondary); text-transform: uppercase;">Verification • Adjustment • Reliability • Improvement</p>
    </div>

    <!-- Feedback Loop Arrow (SVG) -->
