    <div style="flex: 1; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--blue-accent); padding: var(--spacing-sm); border-radius: 6px; text-align: center; position: relative; z-index: 2; box-shadow: 0 2px 8px rgba(0,0,0,0.2); display: flex; flex-direction: column;">
